API_PORT=3000

# Producción en Vercel:
# Crea un almacenamiento KV/Redis en Vercel Marketplace o Upstash.
# Luego pega estas variables en Vercel > Settings > Environment Variables.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# También se reconocen estos nombres si tu integración los entrega así:
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
